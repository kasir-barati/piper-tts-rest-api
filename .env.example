NODE_ENV=production
PORT=3000
PIPER_MODEL=/app/models/en_US-lessac-medium.onnx
MAX_CONCURRENCY=15
LOGGING_MODE=PLAIN_TEXT
LOGGING_LEVEL=info
SERVICE_NAME=piper-tts-rest-api

OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_BATCH_MAX_PENDING_SPANS=2048
OTEL_BATCH_SPANS_PER_EXPORT=512
OTEL_BATCH_FLUSH_INTERVAL_MS=5000
OTEL_BATCH_EXPORT_TIMEOUT_MS=30000

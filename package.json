{
  "name": "piper-tts-rest-api",
  "version": "2.1.0",
  "description": "Convert markdown files to audio using text-to-speech with Piper",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "lint": "eslint src/ --fix",
    "format": "prettier . -w -u",
    "prepare": "husky || true"
  },
  "keywords": [
    "esm",
    "nodejs",
    "typescript",
    "audio",
    "tts",
    "text-to-speech",
    "piper",
    "docker",
    "rest-api",
    "ffmpeg"
  ],
  "author": "Kasir Barati",
  "license": "MIT",
  "engines": {
    "node": "v24.13.0"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.13",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3"
  }
}

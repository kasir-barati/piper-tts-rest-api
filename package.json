{
  "name": "piper-tts-rest-api",
  "version": "2.1.0",
  "description": "Convert markdown files to audio using text-to-speech with Piper",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "format": "prettier . -w -u"
  },
  "keywords": [
    "esm",
    "nodejs",
    "typescript",
    "audio",
    "tts",
    "text-to-speech",
    "piper",
    "docker",
    "rest-api",
    "ffmpeg"
  ],
  "author": "Kasir Barati",
  "license": "MIT",
  "engines": {
    "node": "v24.13.0"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@types/node": "^24.10.13",
    "prettier": "^3.8.1",
    "typescript": "^6.0.3"
  }
}
